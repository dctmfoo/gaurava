    "appIntent.logSideEffect.description": {
      "comment": "App Intent description for opening side-effect capture.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Gaurava to note a side effect for today."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आज का साइड इफेक्ट नोट करने के लिए Gaurava खोलें."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இன்றைய பக்க விளைவை குறிக்க Gaurava-வைத் திறக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈరోజు దుష్ప్రభావాన్ని నమోదు చేయడానికి Gaurava తెరవండి."
          }
        }
      }
    },
    "appIntent.logSideEffect.title": {
      "comment": "App Intent title for opening side-effect capture.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log a Side Effect"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साइड इफेक्ट दर्ज करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பக்க விளைவைப் பதிவு செய்யவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "దుష్ప్రభావాన్ని నమోదు చేయండి"
          }
        }
      }
    },
    "appIntent.openJabs.description": {
      "comment": "App Intent description for opening the injections screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Gaurava to your injections."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने इंजेक्शन देखने के लिए Gaurava खोलें."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் ஊசி பதிவுகளைப் பார்க்க Gaurava-வைத் திறக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ ఇంజెక్షన్లను చూడడానికి Gaurava తెరవండి."
          }
        }
      }
    },
    "appIntent.openJabs.title": {
      "comment": "App Intent title for opening the injections screen.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Jabs"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इंजेक्शन खोलें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஊசிகளைத் திறக்கவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఇంజెక్షన్లను తెరవండి"
          }
        }
      }
    },
    "appIntent.openLog.description": {
      "comment": "App Intent description for opening the daily log.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Gaurava to the daily log."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दैनिक लॉग देखने के लिए Gaurava खोलें."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தினசரி பதிவைப் பார்க்க Gaurava-வைத் திறக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "రోజువారీ లాగ్‌ను చూడడానికి Gaurava తెరవండి."
          }
        }
      }
    },
    "appIntent.openLog.title": {
      "comment": "App Intent title for opening the daily log.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Log"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लॉग खोलें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பதிவேட்டைத் திறக்கவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "లాగ్‌ను తెరవండి"
          }
        }
      }
    },
    "appIntent.openWeight.description": {
      "comment": "App Intent description for opening the weight summary.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Gaurava to your weight summary."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपना वजन सारांश देखने के लिए Gaurava खोलें."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் எடை சுருக்கத்தைப் பார்க்க Gaurava-வைத் திறக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ బరువు సారాంశాన్ని చూడడానికి Gaurava తెరవండి."
          }
        }
      }
    },
    "appIntent.openWeight.title": {
      "comment": "App Intent title for opening the weight summary.",
