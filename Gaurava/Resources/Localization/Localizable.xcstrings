        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "రిమైండర్‌లను ఆన్ చేయండి."
          }
        }
      }
    },
    "Reminders are on.": {
      "comment": "Injection reminders onboarding confirmation (docs/injection-reminders-plan.html, 3b). Manual key hidden from extraction.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
