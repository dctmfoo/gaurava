    "A direction you set — adjust it anytime in Care.": {
      "comment": "id=onboarding.split.goal_why; Surface=Onboarding goal-weight screen why-line.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A direction you set — adjust it anytime in Care."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "आप जो दिशा तय करते हैं — इसे देखभाल में कभी भी बदलें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "நீங்கள் அமைக்கும் ஒரு திசை — கவனிப்பு பிரிவில் எந்த நேரத்திலும் அதை மாற்றிக்கொள்ளலாம்."
