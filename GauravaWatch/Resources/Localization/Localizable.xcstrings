          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "अगली खुराक में %lld दिन"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "अगली खुराक में %lld दिन"
