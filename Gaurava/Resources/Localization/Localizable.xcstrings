    "Plan first. No dose is logged and no countdown starts.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: first-run onboarding. Role: status option subtitle.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plan first. No dose is logged and no countdown starts."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहले योजना बनाएं। कोई खुराक दर्ज नहीं की जाएगी और कोई काउंटडाउन शुरू नहीं होगा।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "முதலில் திட்டமிடுங்கள். எந்த அளவும் பதிவாகாது, கவுண்ட்டவுனும் தொடங்காது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మొదట ప్లాన్ చేయండి. ఎటువంటి మోతాదు నమోదు చేయబడదు మరియు కౌంట్‌డౌన్ ప్రారంభం కాదు."
          }
        }
      }
    },
    "Plan your weekly jab so Jabs can guide you before your first log.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने साप्ताहिक जाब की योजना बनाएं ताकि जैब्स आपके पहले लॉग से पहले आपका मार्गदर्शन कर सकें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் வாராந்திர ஊசியைத் திட்டமிடுங்கள், இதனால் முதல் பதிவுக்கு முன் ‘ஊசிகள்’ தாவல் உங்களுக்கு வழிகாட்டும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ మొదటి లాగ్‌కు ముందు జాబ్స్ మీకు మార్గనిర్దేశం చేయగలగాలి కాబట్టి మీ వారపు జాబ్‌ని ప్లాన్ చేయండి."
          }
        }
      }
    },
    "Planned Dose": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नियोजित खुराक"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "திட்டமிடப்பட்ட அளவு"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రణాళికాబద్ధమైన మోతాదు"
          }
        }
      }
    },
    "Planned dose": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नियोजित खुराक"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "திட்டமிடப்பட்ட அளவு"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రణాళికాబద్ధమైన మోతాదు"
          }
        }
      }
    },
    "Planned for %@": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: planned weekday line with formatted weekday placeholder.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Planned for %@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ के लिए नियोजित"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ அன்று திட்டமிடப்பட்டுள்ளது"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ కోసం ప్లాన్ చేయబడింది"
          }
        }
      }
    },
    "Planned for every %@ — log your first jab to confirm": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर %@ के लिए योजना बनाई गई — पुष्टि करने के लिए अपना पहला जैब लॉग करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஒவ்வொரு %@-க்கும் திட்டமிடப்பட்டுள்ளது — உறுதிப்படுத்த உங்கள் முதல் ஜாப்பை பதிவு செய்யவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రతి %@కి ప్లాన్ చేయబడింది — నిర్ధారించడానికి మీ మొదటి జబ్‌ను లాగిన్ చేయండి"
          }
        }
      }
    },
    "Planned for every %@. No countdown yet.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: first-run onboarding. Role: format sentence with localized weekday placeholder.",
      "extractionState": "manual",
      "localizations": {
