    },
    "Planning day?": {
      "comment": "id=onboarding.start.day.title; Surface=Onboarding just-starting weekly planning step hero title; optional future plan; not a confirmed dose.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Planning day?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "திட்டமிடும் நாளா?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "योजना का दिन?"
          }
