        }
      }
    },
    "This removes the selected injection from your history.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह आपके इतिहास से चयनित इंजेक्शन को हटा देता है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இது உங்கள் வரலாற்றிலிருந்து தேர்ந்தெடுக்கப்பட்ட ஊசியை நீக்குகிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఇది మీ చరిత్ర నుండి ఎంచుకున్న ఇంజెక్షన్‌ను తీసివేస్తుంది."
          }
        }
      }
    },
    "This removes the selected weight entry from your trend.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह आपकी प्रवृत्ति से चयनित वजन प्रविष्टि को हटा देता है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இது உங்கள் போக்கிலிருந்து தேர்ந்தெடுக்கப்பட்ட எடை உள்ளீட்டை நீக்குகிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఇది మీ ట్రెండ్ నుండి ఎంచుకున్న బరువు నమోదును తీసివేస్తుంది."
          }
        }
      }
    },
