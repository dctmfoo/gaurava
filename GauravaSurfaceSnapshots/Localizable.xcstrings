        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பராமரிப்புச் செயல்கள்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "సంరక్షణ చర్యలు"
          }
        }
      }
    },
    "Care Glance": {
      "extractionState": "stale",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "देखभाल झलक"
