    "We schedule only from a dose you confirm — never from an old start date.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: care sheet footnote for active status.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We schedule only from a dose you confirm — never from an old start date."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम केवल आपके द्वारा पुष्टि की गई खुराक से शेड्यूल करते हैं — कभी भी पुरानी शुरुआती तारीख से नहीं।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நீங்கள் உறுதிப்படுத்தும் மருந்தளவிலிருந்து மட்டுமே நாங்கள் அட்டவணைப்படுத்துவோம் — பழைய தொடக்கத் தேதியிலிருந்து அல்ல."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీరు ధృవీకరించిన మోతాదు నుండి మాత్రమే మేము షెడ్యూల్ చేస్తాము — పాత ప్రారంభ తేదీ నుండి కాదు."
          }
        }
      }
    },
    "We'll ask for your latest dose date next.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: first-run onboarding. Role: status option subtitle.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll ask for your latest dose date next."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम आगे आपकी नवीनतम खुराक की तारीख पूछेंगे।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அடுத்து உங்கள் சமீபத்திய மருந்தளவு தேதியை நாங்கள் கேட்போம்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మేము తర్వాత మీ తాజా మోతాదు తేదీని అడుగుతాము."
          }
        }
      }
    },
    "We'll pause your schedule — no reminders, no overdue.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: care sheet footnote for paused status.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll pause your schedule — no reminders, no overdue."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम आपका शेड्यूल रोक देंगे — कोई रिमाइंडर नहीं, कोई ओवरड्यू नहीं।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் அட்டவணையை இடைநிறுத்துவோம் — நினைவூட்டல்களோ, நிலுவைகளோ இருக்காது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మేము మీ షెడ్యూల్‌ను నిలిపివేస్తాము — ఎటువంటి రిమైండర్‌లు, గడువు ముగిసినవి ఉండవు."
          }
        }
      }
    },
    "We'll pick your schedule back up from your next logged dose.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: confirmation message.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We'll pick your schedule back up from your next logged dose."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम आपकी अगली दर्ज की गई खुराक से आपका शेड्यूल फिर से शुरू कर देंगे।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் அடுத்த பதிவு செய்யப்பட்ட அளவிலிருந்து உங்கள் அட்டவணையை நாங்கள் மீண்டும் தொடங்குவோம்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీరు నమోదు చేసే తదుపరి డోస్ నుండి మేము మీ షెడ్యూల్‌ను మళ్లీ ప్రారంభిస్తాము."
          }
        }
      }
    },
    "Week %lld": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सप्ताह %lld"
