        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్లానింగ్ రోజా?"
          }
        }
      }
    },
    "Optional. A plan only, no countdown yet.": {
      "comment": "id=onboarding.start.day.subtitle; Surface=Onboarding weekly planning step subtitle; schedule honesty; no confirmed dose and no live countdown.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. A plan only, no countdown yet."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "விருப்பத்திற்குரியது. ஒரு திட்டம் மட்டுமே, இன்னும் கவுண்ட்டவுன் இல்லை."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वैकल्पिक। केवल एक योजना, अभी कोई उलटी गिनती नहीं।"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఐచ్ఛికం. కేవలం ఒక ప్లాన్ మాత్రమే, ఇంకా కౌంట్‌డౌన్ లేదు."
          }
        }
      },
      "extractionState": "manual"
    },
    "Latest dose": {
      "comment": "id=onboarding.active.latest.title; Surface=Onboarding active track latest dose hero title; most recent dose date prompt.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Latest dose"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சமீபத்திய அளவு"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नवीनतम खुराक"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఇటీవలి మోతాదు"
          }
        }
      },
      "extractionState": "manual"
    },
    "Your schedule counts from this dose.": {
      "comment": "id=onboarding.active.latest.subtitle; Surface=Onboarding active track latest dose subtitle; schedule honesty; only confirmed dose anchors schedule.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your schedule counts from this dose."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் அட்டவணை இந்த அளவிலிருந்து கணக்கிடப்படும்."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका शेड्यूल इस खुराक से गिना जाता है।"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ షెడ్యూల్ ఈ మోతాదు నుండి లెక్కించబడుతుంది."
          }
        }
      },
      "extractionState": "manual"
    },
    "For tracking only. No dosing advice.": {
      "comment": "id=onboarding.active.dose_safety; Surface=Onboarding active medicine dose safety note; clinical safety; preserve no-dosing-advice meaning.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For tracking only. No dosing advice."
          }
