          }
        }
      },
      "extractionState": "manual"
    },
    "Bring your weights": {
      "comment": "id=onboarding.split.health_title; Surface=Onboarding Apple Health screen title.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring your weights"
