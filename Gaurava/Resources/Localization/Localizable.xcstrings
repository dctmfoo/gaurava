          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नोट जोड़ें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "குறிப்பைச் சேர்க்கவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "గమనికను జోడించండి"
          }
        }
      }
    },
    "Add a weight checkpoint before creating a journey card.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यात्रा कार्ड बनाने से पहले वज़न चेकपॉइंट जोड़ें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பயண அட்டையை உருவாக்கும் முன் ஒரு எடைப் பதிவைச் சேர்க்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రయాణ కార్డ్‌ని సృష్టించే ముందు బరువు చెక్‌పాయింట్‌ని జోడించండి."
          }
        }
      }
    },
    "Add a weight entry before creating a share card.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शेयर कार्ड बनाने से पहले एक वजन प्रविष्टि जोड़ें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பங்கு அட்டையை உருவாக்கும் முன் எடை உள்ளீட்டைச் சேர்க்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "షేర్ కార్డ్‌ని సృష్టించే ముందు బరువు నమోదును జోడించండి."
          }
        }
      }
    },
    "Add a weight entry to create a card.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कार्ड बनाने के लिए वजन प्रविष्टि जोड़ें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கார்டை உருவாக்க எடை உள்ளீட்டைச் சேர்க்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "కార్డ్‌ని సృష్టించడానికి బరువు ఎంట్రీని జోడించండి."
          }
        }
      }
    },
    "Add age, height, and other basics when useful.": {
      "comment": "Surface: Care personal details card. Role: empty state when no profile details have been saved.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add age, height, and other basics when useful."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ज़रूरत पड़ने पर उम्र, लंबाई और अन्य बुनियादी जानकारी जोड़ें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "தேவைப்படும் போது வயது, உயரம் மற்றும் பிற அடிப்படை விவரங்களைச் சேர்க்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఉపయోగపడినప్పుడు వయస్సు, ఎత్తు మరియు ఇతర ప్రాథమిక వివరాలను జోడించండి."
          }
        }
      }
    },
    "Add a weight, injection, or daily note to begin your timeline.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी टाइमलाइन शुरू करने के लिए वजन, इंजेक्शन या दैनिक नोट जोड़ें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் காலவரிசையைத் தொடங்க எடை, ஊசி அல்லது தினசரி குறிப்பைச் சேர்க்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ టైమ్‌లైన్‌ను ప్రారంభించడానికి బరువు, ఇంజెక్షన్ లేదా రోజువారీ గమనికను జోడించండి."
          }
        }
      }
    },
