.DS_Store
.env
.env.*
!.env.example

# Maintainer-specific signing + ASC values (team ID, profile UUIDs). Never
# tracked — forks create their own if they use the device/TestFlight lanes.
Makefile.local
private/

build/
DerivedData/
*.ipa
*.xcarchive/
*.xcresult/
*.mobileprovision
*.provisionprofile
*.p12
*.cer
*.xcuserdata/
xcuserdata/
*.xcuserstate

scratch/*
!scratch/.gitignore
output/

# Python bytecode cache (e.g. from scripts/check_localization.py imports)
__pycache__/
*.pyc

# Browser-tool (Playwright / Claude-in-Chrome MCP) cache: console logs and
# page snapshots written during verification. Local-only, safe to delete.
.playwright-mcp/

# Session-hook runtime markers (Stop-hook loop-prevention touchstones).
# Local-only state, never source. See .claude/hooks/ + CLAUDE.md "Session
# Journal Discipline".
.claude/state/
.claude/scheduled_tasks.lock
.claude/skills/gaurava-store-screenshots/assets/captures*/
.claude/skills/gaurava-store-screenshots/assets/out*/

docs/apple/
docs/test-journey-12-weeks.json
docs/archived/test-journey-12-weeks.json
Build/DocIndex/

# Gaurava store-screenshot skill — regenerable captures & renders (re-run the
# MarketingScreenshotTests + GauravaSurfaceSnapshots to recreate). Final decks
# live in docs/assets/app-store-screenshots/.
.claude/skills/gaurava-store-screenshots/assets/out/
.claude/skills/gaurava-store-screenshots/assets/out-minihue/
.claude/skills/gaurava-store-screenshots/assets/poc/
.claude/skills/gaurava-store-screenshots/assets/captures/
.claude/skills/gaurava-store-screenshots/assets/surfaces/

# Same regenerables at the skill's new canonical home under .agents/skills/
# (other skills live there with symlinks from .claude/skills/).
.agents/skills/gaurava-store-screenshots/assets/captures*/
.agents/skills/gaurava-store-screenshots/assets/out*/
.agents/skills/gaurava-store-screenshots/assets/poc/
.agents/skills/gaurava-store-screenshots/assets/surfaces/

# Local agent session-name marker (regenerated by resolve_agent_name.sh)
/agents/

# Local-only release material (kept on disk, never version-controlled):
# App Store Connect operational state driving the maintainer's release process.
/ASC.md
