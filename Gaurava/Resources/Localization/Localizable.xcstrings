      }
    },
    "Symptom and note entries only.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "केवल लक्षण और नोट प्रविष्टियाँ।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "அறிகுறிகள் மற்றும் குறிப்பு உள்ளீடுகள் மட்டுமே."
