    },
    "The clinician image could not be rendered.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "चिकित्सक की छवि प्रस्तुत नहीं की जा सकी।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "மருத்துவரின் படத்தை வழங்க முடியவில்லை."
          }
