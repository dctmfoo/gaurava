          }
        }
      }
    },
    "Self-logged, never advised": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वयं दर्ज किया गया, कभी सलाह नहीं"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நீங்களே பதிவு செய்வது, ஆலோசனை அல்ல"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీరు స్వయంగా నమోదు చేసినది, సలహా కాదు"
          }
        }
      }
    },
    "Self-reported. Not medical advice and not a diagnostic record. Counts, severities, and notes are entered by the patient; the dose history is self-logged from the injection record.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्व-रिपोर्ट किया गया। न चिकित्सीय सलाह और न ही निदान संबंधी रिकार्ड। गिनती, गंभीरता और नोट्स रोगी द्वारा दर्ज किए जाते हैं; खुराक का इतिहास इंजेक्शन रिकॉर्ड से स्व-लॉग किया गया है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சுய அறிக்கை. மருத்துவ ஆலோசனை அல்ல, நோயறிதல் பதிவு அல்ல. எண்ணிக்கைகள், தீவிரங்கள் மற்றும் குறிப்புகள் நோயாளியால் உள்ளிடப்படுகின்றன; அளவு வரலாறு ஊசி பதிவிலிருந்து சுயமாக பதிவு செய்யப்பட்டுள்ளது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "స్వయంగా నివేదించారు. వైద్య సలహా కాదు మరియు డయాగ్నస్టిక్ రికార్డ్ కాదు. గణనలు, తీవ్రతలు మరియు గమనికలు రోగిచే నమోదు చేయబడతాయి; ఇంజెక్షన్ రికార్డ్ నుండి మోతాదు చరిత్ర స్వీయ-లాగ్ చేయబడింది."
          }
        }
      }
    },
    "Semaglutide": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेमाग्लूटाइड"
