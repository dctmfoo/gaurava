    "glance.dayCaption.daysToNextDose": {
      "comment": "Compact day caption showing days until the next dose.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
