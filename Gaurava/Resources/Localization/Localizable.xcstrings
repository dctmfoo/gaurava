    },
    "Dose reminders?": {
      "comment": "Injection reminders onboarding discovery step header (docs/injection-reminders-plan.html, 3b). Manual key hidden from extraction.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dose reminders?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "खुराक की याद दिलाना?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மருந்தளவு நினைவூட்டல்கள் வேண்டுமா?"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "డోస్ రిమైండర్‌లు కావాలా?"
          }
        }
      }
    },
    "Optional. A nudge the day before each dose.": {
      "comment": "Injection reminders onboarding discovery step subtitle (docs/injection-reminders-plan.html, 3b). Manual key hidden from extraction.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. A nudge the day before each dose."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "वैकल्पिक। प्रत्येक खुराक से एक दिन पहले एक धकेलना।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "விருப்பத்திற்குரியது. ஒவ்வொரு அளவுக்கும் முந்தைய நாளில் ஒரு நினைவூட்டல்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ఐచ్ఛికం. ప్రతి డోసుకు ముందు రోజు ఒక చిన్న ప్రోత్సాహం."
          }
        }
      }
    },
    "Get a reminder the day before each dose?": {
      "comment": "Injection reminders onboarding priming question (docs/injection-reminders-plan.html, 3b). Manual key hidden from extraction.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get a reminder the day before each dose?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "क्या आपको प्रत्येक खुराक से एक दिन पहले एक अनुस्मारक मिलता है?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஒவ்வொரு அளவுக்கும் முந்தைய நாளில் நினைவூட்டல் பெறவா?"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ప్రతి డోస్ ముందు రోజు గుర్తు చేయాలా?"
          }
        }
      }
    },
    "Turn on reminders": {
      "comment": "Injection reminders onboarding opt-in button (docs/injection-reminders-plan.html, 3b). Manual key hidden from extraction.",
      "extractionState": "manual",
      "localizations": {
        "en": {
