    "Set your medication and dose so Gaurava can guide your schedule.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: empty treatment card summary.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set your medication and dose so Gaurava can guide your schedule."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी दवा और खुराक सेट करें ताकि Gaurava आपके शेड्यूल का मार्गदर्शन कर सके।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava உங்கள் அட்டவணையை வழிநடத்த, உங்கள் மருந்து மற்றும் மருந்தளவை அமைக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava మీ షెడ్యూల్‌ను నిర్దేశించడానికి మీ మందులు మరియు మోతాదును సెట్ చేయండి."
          }
        }
      }
    },
