    "Your history baseline counts from this day.": {
      "comment": "id=onboarding.split.treatment_start_why; Surface=Onboarding treatment-start screen why-line.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your history baseline counts from this day."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "आपके इतिहास की आधार रेखा इसी दिन से गिनी जाती है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "உங்கள் வரலாறு இந்த நாளிலிருந்து கணக்கிடப்படுகிறது."
          }
