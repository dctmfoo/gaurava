    "No reminders. Resume anytime.": {
      "comment": "id=onboarding.paused.subtitle; Surface=Onboarding paused hidden track hero subtitle; no reminders/no overdue meaning.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No reminders. Resume anytime."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நினைவூட்டல்கள் இல்லை. எப்போது வேண்டுமானாலும் தொடரலாம்."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई रिमाइंडर नहीं। कभी भी दोबारा शुरू करें।"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "రిమైండర్‌లు లేవు. ఎప్పుడైనా మళ్లీ ప్రారంభించండి."
          }
        }
      },
      "extractionState": "manual"
    },
    "Change later in Care.": {
      "comment": "id=onboarding.shared.footer; Surface=Shared onboarding footer under setup steps; reassurance that setup can be edited later in Care tab.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change later in Care."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பின்னர் கவனிப்பு பிரிவில் மாற்றிக்கொள்ளலாம்."
          }
