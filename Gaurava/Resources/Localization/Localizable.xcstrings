      }
    },
    "Optional — slide to choose": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "वैकल्पिक — चुनने के लिए स्लाइड करें"
