    },
    "Double tap to collapse side effects": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "दुष्प्रभावों को हटाने के लिए दो बार टैप करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "பக்க விளைவுகளைக் குறைக்க இருமுறை தட்டவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "దుష్ప్రభావాలను తగ్గించడానికి రెండుసార్లు నొక్కండి."
          }
        }
      }
    },
    "Estimated from the weigh-ins nearest each dose change.": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "प्रत्येक खुराक परिवर्तन के निकटतम भार-अभिगमन से अनुमान लगाया गया।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ஒவ்வொரு மருந்தளவு மாற்றத்திற்கும் அருகிலுள்ள எடை அளவீடுகளிலிருந்து மதிப்பிடப்படுகிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ప్రతి మోతాదు మార్పుకు దగ్గరగా ఉన్న బరువుల నుండి అంచనా వేయబడింది."
          }
        }
      }
    },
    "Estimated from the weigh-ins nearest each dose change. Paused time is left out of durations and weekly rates.": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "प्रत्येक खुराक परिवर्तन के सबसे नज़दीकी वज़न से अनुमान लगाया गया। ठहरा हुआ समय अवधि और साप्ताहिक दरों से बाहर रखा गया है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஒவ்வொரு அளவு மாற்றத்திற்கும் அருகிலுள்ள எடை அளவீடுகளிலிருந்து மதிப்பிடப்பட்டது. இடைநிறுத்தப்பட்ட நேரம் கால அளவுகள் மற்றும் வாராந்திர விகிதங்களில் இருந்து விடுபட்டுள்ளது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ప్రతి డోస్ మార్పుకు దగ్గరగా ఉన్న బరువుల నుండి అంచనా వేయబడింది. విరామ సమయం వ్యవధులు మరియు వారపు రేట్లలో వదిలివేయబడింది."
          }
        }
      }
    },
    "Goal set": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "लक्ष्य निर्धारित किया गया"
