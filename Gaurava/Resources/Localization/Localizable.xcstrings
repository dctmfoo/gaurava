        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "கண்காணிப்பிற்கு மட்டுமே. மருந்தளவு ஆலோசனை அல்ல."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल ट्रैकिंग के लिए। खुराक की कोई सलाह नहीं।"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ట్రాకింగ్ కోసం మాత్రమే. మోతాదు సలహా కాదు."
