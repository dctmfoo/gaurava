      }
    },
    "Swipe up or down to adjust": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "समायोजित करने के लिए ऊपर या नीचे स्वाइप करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "சரிசெய்ய மேல் அல்லது கீழ் ஸ்வைப் செய்யவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "సర్దుబాటు చేయడానికి పైకి లేదా క్రిందికి స్వైప్ చేయండి."
          }
        }
      }
    },
    "Swipe up or down to adjust. Double tap the selected value to clear it.": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "समायोजित करने के लिए ऊपर या नीचे स्वाइप करें। चयनित मान को साफ़ करने के लिए उस पर दो बार टैप करें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "சரிசெய்ய மேல் அல்லது கீழ் ஸ்வைப் செய்யவும். தேர்ந்தெடுக்கப்பட்ட மதிப்பை நீக்க அதை இருமுறை தட்டவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "సర్దుబాటు చేయడానికి పైకి లేదా క్రిందికి స్వైప్ చేయండి. ఎంచుకున్న విలువను తొలగించడానికి దానిపై రెండుసార్లు నొక్కండి."
          }
        }
      }
    },
    "You have crossed 10% from your starting weight.": {
      "extractionState": "manual",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "आपने अपने शुरुआती वज़न से 10% पार कर लिया है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "நீங்கள் உங்கள் ஆரம்ப எடையில் இருந்து 10% கடந்துவிட்டீர்கள்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "మీరు మీ ప్రారంభ బరువు నుండి 10% దాటారు."
          }
        }
      }
    },
    "You have crossed 5% from your starting weight.": {
      "extractionState": "manual",
      "localizations": {
