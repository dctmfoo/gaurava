        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दर्ज किया गया, कोई गंभीरता नहीं चुनी गई"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "பதிவு செய்யப்பட்டது, தீவிரத்தன்மை எதுவும் தேர்ந்தெடுக்கப்படவில்லை"
          }
