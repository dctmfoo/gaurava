    "A private treatment progress card from Gaurava.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava से एक निजी उपचार प्रगति कार्ड।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava இலிருந்து ஒரு தனிப்பட்ட சிகிச்சை முன்னேற்ற அட்டை."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava నుండి ప్రైవేట్ చికిత్స ప్రోగ్రెస్ కార్డ్."
          }
        }
      }
    },
    "A sense of the day": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दिन का एक अहसास"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இன்றைய நாளின் உணர்வு"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈ రోజు గురించిన భావన"
          }
        }
      }
    },
    "A steady, private place to track treatment.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उपचार को ट्रैक करने के लिए एक स्थिर, निजी स्थान."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சிகிச்சையைக் கண்காணிக்க ஒரு நிலையான, தனிப்பட்ட இடம்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "చికిత్సను ట్రాక్ చేయడానికి ఒక స్థిరమైన, వ్యక్తిగత స్థలం."
          }
        }
      }
    },
    "About Gaurava": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava के बारे में"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava பற்றி"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava గురించి"
          }
        }
      }
    },
