    },
    "Add your latest injection to restart your schedule.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपना शेड्यूल फिर से शुरू करने के लिए अपना नवीनतम इंजेक्शन जोड़ें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் அட்டவணையை மீண்டும் தொடங்க உங்கள் சமீபத்திய ஊசியைச் சேர்க்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ షెడ్యూల్‌ను మళ్లీ ప్రారంభించడానికి మీ ఇటీవలి ఇంజెక్షన్‌ను జోడించండి."
          }
        }
      }
    },
    "Add your most recent dose to set your schedule.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: needs-confirmation schedule line.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add your most recent dose to set your schedule."
