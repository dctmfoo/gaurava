    "NSPhotoLibraryAddUsageDescription": {
      "comment": "Photos permission prompt shown when the user asks to save journey cards.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava saves journey cards to your Photos library when you ask."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके पूछने पर Gaurava आपकी फ़ोटो लाइब्रेरी में यात्रा कार्ड सहेजता है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நீங்கள் கேட்கும் போது Gaurava பயண அட்டைகளை உங்கள் புகைப்பட நூலகத்தில் சேமிக்கிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీరు అడిగినప్పుడు Gaurava మీ ఫోటోల లైబ్రరీకి ప్రయాణ కార్డ్‌లను సేవ్ చేస్తుంది."
          }
        }
      }
    }
  },
  "version": "1.0"
}
