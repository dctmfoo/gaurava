        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ताकि आपकी प्रगति को मापने के लिए एक आधार रेखा हो।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "எனவே உங்கள் முன்னேற்றத்தை அளவிட ஒரு அடிப்படை உள்ளது."
