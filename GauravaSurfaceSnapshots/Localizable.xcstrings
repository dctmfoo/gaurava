        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वजन खोलें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "எடையைத் திறக்கவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "బరువును తెరవండి"
          }
        }
      }
    },
    "Care Actions": {
      "extractionState": "stale",
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "देखभाल क्रियाएं"
