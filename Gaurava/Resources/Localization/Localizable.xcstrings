        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपना शेड्यूल सेट करने के लिए अपनी सबसे हालिया खुराक जोड़ें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் அட்டவணையை அமைக்க, உங்களது மிகச் சமீபத்திய மருந்தளவைச் சேர்க்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ షెడ్యూల్‌ను సెట్ చేయడానికి మీ ఇటీవలి మోతాదును జోడించండి."
          }
        }
      }
    },
