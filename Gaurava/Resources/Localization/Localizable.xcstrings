    "Update this whenever your treatment changes. Everything stays optional.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: care treatment sheet helper.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update this whenever your treatment changes. Everything stays optional."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब भी आपका इलाज बदले, इसे अपडेट करें। सब कुछ वैकल्पिक है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் சிகிச்சை மாறும்போது இதை எப்போதும் புதுப்பிக்கவும். அனைத்தும் விருப்பத்தேர்வாகவே இருக்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ చికిత్స మారినప్పుడల్లా దీన్ని నవీకరించండి. అంతా ఐచ్ఛికంగానే ఉంటుంది."
          }
        }
      }
    },
    "Update treatment details": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: care treatment card action.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update treatment details"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इलाज के विवरण अपडेट करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சிகிச்சை விவரங்களைப் புதுப்பிக்கவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "చికిత్స వివరాలను నవీకరించండి"
          }
        }
      }
    },
    "Used for context in charts and clinician export.": {
      "comment": "Surface: Care personal details card. Role: subtitle explaining why personal details are useful.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used for context in charts and clinician export."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चार्ट और चिकित्सक निर्यात में संदर्भ के लिए उपयोग किया जाता है।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "வரைபடங்களிலும் மருத்துவர் ஏற்றுமதியிலும் சூழலுக்குப் பயன்படுத்தப்படுகிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "చార్ట్‌లు మరియు వైద్యుని ఎగుమతిలో సందర్భం కోసం ఉపయోగించబడుతుంది."
          }
        }
      }
    },
    "Use all sites": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सभी स्थानों का उपयोग करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அனைத்து இடங்களையும் பயன்படுத்தவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "అన్ని స్థలాలను ఉపయోగించండి"
          }
        }
      }
    },
    "Use preferred day": {
      "localizations": {
        "hi": {
          "stringUnit": {
