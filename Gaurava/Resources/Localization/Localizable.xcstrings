    "Leave this unset to keep things calm and unscheduled.": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: care sheet footnote for unknown status.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave this unset to keep things calm and unscheduled."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चीजों को शांत और अनिर्धारित रखने के लिए इसे अनसेट छोड़ दें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "விஷயங்களை அமைதியாகவும் திட்டமிடப்படாமலும் வைத்திருக்க, இதை அமைக்காமல் விட்டுவிடவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రశాంతంగా మరియు షెడ్యూల్ లేకుండా ఉంచడానికి దీన్ని సెట్ చేయకుండా వదిలేయండి."
          }
        }
      }
    },
    "Less than 1 week at this dose": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस खुराक पर 1 सप्ताह से कम"
