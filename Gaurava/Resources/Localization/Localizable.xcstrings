    "Have you *started* GLP-1 yet?": {
      "comment": "id=onboarding.status.question; Surface=Onboarding status step headline question. The word wrapped in *asterisks* renders as a serif-italic accent in our primary green. Emphasis is OPTIONAL per language — a translation may omit the *…* (renders plain). Keep GLP-1 unchanged; compact mobile heading.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Have you *started* GLP-1 yet?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या GLP-1 शुरू कर दिया है?"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "GLP-1 ஐத் தொடங்கிவிட்டீர்களா?"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
