          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "अनुस्मारक चालू हैं।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "நினைவூட்டல்கள் இயக்கப்பட்டுள்ளன."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "రిమైండర్‌లు ఆన్‌లో ఉన్నాయి."
          }
        }
      }
    },
    "Turn on notifications in Settings": {
      "comment": "Injection reminders Care toggle (docs/injection-reminders-plan.html). Manual key hidden from extraction.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on notifications in Settings"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "सेटिंग्स में नोटिफ़िकेशन चालू करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "அமைப்புகளில் அறிவிப்புகளை இயக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "సెట్టింగ్స్‌లో నోటిఫికేషన్‌లను ఆన్ చేయండి."
          }
        }
      }
    },
    "To get dose reminders, allow notifications for Gaurava in Settings.": {
      "comment": "Injection reminders Care toggle (docs/injection-reminders-plan.html). Manual key hidden from extraction.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To get dose reminders, allow notifications for Gaurava in Settings."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "खुराक अनुस्मारक प्राप्त करने के लिए, सेटिंग्स में गौरव के लिए सूचनाएं सक्षम करें।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மருந்தளவு நினைவூட்டல்களைப் பெற, அமைப்புகளில் Gaurava-விற்கான அறிவிப்புகளை அனுமதிக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "డోస్ రిమైండర్‌లను పొందడానికి, సెట్టింగ్‌లలో గౌరవ కోసం నోటిఫికేషన్‌లను అనుమతించండి."
          }
        }
      }
    },
    "From Apple Health": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "एप्पल हेल्थ से"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Health-லிருந்து"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ఆపిల్ హెల్త్ నుండి"
          }
        }
      }
    },
    "Apple Health": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "एप्पल हेल्थ"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Health"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ఆపిల్ ఆరోగ్యం"
          }
        }
      }
    },
    "Import weight": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "वज़न आयात करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "எடையை இறக்குமதி செய்யவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "బరువును దిగుమతి చేయండి"
          }
        }
      }
    },
    "Connected": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "जुड़ा हुआ"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "இணைக்கப்பட்டது"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "కనెక్ట్ చేయబడింది"
          }
        }
      }
    },
    "Import weight from Apple Health": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "एप्पल हेल्थ से वजन आयात करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Health-லிருந்து எடையை இறக்குமதி செய்யவும்"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ఆపిల్ హెల్త్ నుండి బరువును దిగుమతి చేయండి."
          }
        }
      }
    },
    "Gaurava reads body weight from Apple Health so readings you already logged appear in your trends — automatically, and only when you allow it.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "गौरवा एप्पल हेल्थ से शरीर का वजन पढ़ती है, इसलिए आपके द्वारा पहले से लॉग किए गए रीडिंग आपके रुझानों में दिखाई देते हैं - स्वचालित रूप से, और केवल तभी जब आप इसकी अनुमति देती हैं।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava, Apple Health-லிருந்து உடல் எடையைப் படிக்கிறது; எனவே நீங்கள் ஏற்கனவே பதிவு செய்த அளவீடுகள் உங்கள் போக்குகளில் தானாகவே தோன்றும் — நீங்கள் அனுமதிக்கும்போது மட்டுமே."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "గౌరవ ఆపిల్ హెల్త్ నుండి శరీర బరువును చదువుతుంది, కాబట్టి మీరు ఇప్పటికే లాగ్ చేసిన రీడింగ్‌లు మీ ట్రెండ్‌లలో కనిపిస్తాయి - స్వయంచాలకంగా మరియు మీరు అనుమతించినప్పుడు మాత్రమే."
          }
        }
      }
    },
    "How it works": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "यह कैसे काम करता है"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "இது எப்படி வேலை செய்கிறது"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ఇది ఎలా పనిచేస్తుంది"
          }
        }
      }
    },
    "Gaurava only reads weight. It never writes anything back to Apple Health.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "गौरवा केवल वज़न पढ़ती है। वह कभी भी एप्पल हेल्थ को कुछ वापस नहीं लिखती।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Gaurava எடையை மட்டுமே படிக்கிறது. அது Apple Health-க்கு எதையும் திரும்ப எழுதுவதில்லை."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "గౌరవ బరువు మాత్రమే చదువుతుంది. ఆమె ఎప్పుడూ ఆపిల్ హెల్త్‌కు తిరిగి ఏమీ రాయదు."
          }
        }
      }
    },
    "New readings sync each time you open Gaurava.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "हर बार जब आप गौरव खोलती हैं, तो नए रीडिंग्स सिंक हो जाते हैं।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நீங்கள் ஒவ்வொரு முறை Gaurava-வைத் திறக்கும்போதும் புதிய அளவீடுகள் ஒத்திசைக்கப்படும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "మీరు గౌరవాన్ని తెరిచిన ప్రతిసారీ కొత్త రీడింగ్‌లు సమకాలీకరించబడతాయి."
          }
        }
      }
    },
    "You can disconnect anytime. Imported weights stay in Gaurava.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "आप कभी भी डिस्कनेक्ट कर सकते हैं। आयातित भार गौरव में ही रहते हैं।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நீங்கள் எப்போது வேண்டுமானாலும் துண்டிக்கலாம். இறக்குமதி செய்யப்பட்ட எடைகள் Gaurava-வில் இருக்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "మీరు ఎప్పుడైనా డిస్‌కనెక్ట్ చేయవచ్చు. దిగుమతి చేసుకున్న బరువులు గౌరవలోనే ఉంటాయి."
          }
        }
      }
    },
    "Apple Health is unavailable": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "एप्पल हेल्थ अनुपलब्ध है"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Health கிடைக்கவில்லை"
          }
        },
        "te": {
          "stringUnit": {
            "state": "needs_review",
            "value": "ఆపిల్ హెల్త్ అందుబాటులో లేదు."
          }
        }
      }
    },
    "This device does not have Apple Health, so weight import isn't available here.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "needs_review",
