    "You moved to %@ %lld weeks ago.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You moved to %1$@ %2$lld weeks ago."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने %2$lld सप्ताह पहले %1$@ शुरू किया।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$lld வாரங்களுக்கு முன்பு நீங்கள் %1$@ அளவுக்கு மாறினீர்கள்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$lld వారాల క్రితం మీరు %1$@ మోతాదుకు మారారు."
          }
        }
      }
    },
    "You moved to %@ 1 week ago.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You moved to %@ 1 week ago."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने 1 सप्ताह पहले %@ शुरू किया।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "1 வாரம் முன்பு நீங்கள் %@ அளவுக்கு மாறினீர்கள்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "1 వారం క్రితం మీరు %@ మోతాదుకు మారారు."
          }
        }
      }
    },
    "Your entries stay on device and sync only through your own iCloud.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी प्रविष्टियां डिवाइस पर रहती हैं और केवल आपके अपने iCloud के माध्यम से सिंक होती हैं।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் பதிவுகள் சாதனத்திலேயே இருக்கும், உங்கள் சொந்த iCloud வழியாக மட்டுமே ஒத்திசையும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ నమోదులు పరికరంలోనే ఉంటాయి, మీ స్వంత iCloud ద్వారా మాత్రమే సింక్ అవుతాయి."
          }
        }
      }
    },
    "Your most recent dose — optional": {
      "comment": "Gemini-reviewed localization delta 2026-06-07. Surface: Care treatment status and onboarding sandbox. Role: care sheet section label.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your most recent dose — optional"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी सबसे हालिया खुराक — वैकल्पिक"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்களது மிகச் சமீபத்திய மருந்தளவு — விருப்பத்தேர்வு"
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ ఇటీవలి మోతాదు — ఐచ్ఛికం"
          }
        }
      }
    },
    "Your recent entries show a steady downward trend across %lld weeks.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी हाल की प्रविष्टियां %lld सप्ताहों में स्थिर गिरावट दिखाती हैं।"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் சமீபத்திய பதிவுகள் %lld வாரங்களில் நிலையான குறைவு போக்கைக் காட்டுகின்றன."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ ఇటీవలి నమోదులు %lld వారాల్లో స్థిరమైన తగ్గుదల ధోరణిని చూపుతున్నాయి."
          }
        }
      }
    },
