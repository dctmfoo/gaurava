        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "रिमाइंडर चालू करें"
          }
        },
        "ta": {
          "stringUnit": {
            "state": "needs_review",
            "value": "நினைவூட்டல்களை இயக்கவும்."
